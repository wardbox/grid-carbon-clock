ADMIN_EMAILS=admin@example.com

# WattTime API credentials — free account works for CAISO_NORTH
# Register via API (no web sign-up page):
#   curl -X POST https://api.watttime.org/register \
#     -H 'Content-Type: application/json' \
#     -d '{"username":"you","password":"...","email":"you@example.com","org":"personal"}'
# Full API docs: https://docs.watttime.org
WATTTIME_USERNAME=your_watttime_username
WATTTIME_PASSWORD=your_watttime_password
