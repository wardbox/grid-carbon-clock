// ============================================================================
// DATABASE CONFIGURATION
// Using PostgreSQL. Start with: wasp db start
// ============================================================================
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// ============================================================================
// ENTITIES
// Add your models here. After changes, run: wasp db migrate-dev
// ============================================================================

// User entity - required by Wasp auth
// Add your own fields below the existing ones
model User {
  id          String   @id @default(uuid())
  username    String   @unique
  email       String   @unique
  isAdmin     Boolean  @default(false)
  notifyBelow Int?     // gCO₂/kWh alert threshold — stored, alerting is v2

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model GridReading {
  id        Int      @id @default(autoincrement())
  region    String   @default("CAISO_NORTH")
  ts        DateTime
  moer      Float    // gCO₂/kWh, already converted from lbs CO₂/MWh
  kind      String   // "actual" | "forecast"
  fetchedAt DateTime @default(now())

  @@index([region, ts])
}


